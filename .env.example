# ============================================================
#  AANYA SHARMA — AI Influencer System
#  Copy this to .env and fill in your keys
# ============================================================

# --- LLM APIs (ALL FREE TIERS) ---
GROQ_API_KEY=your_groq_api_key_here              # groq.com — free, fastest
GEMINI_API_KEY=your_gemini_api_key_here          # aistudio.google.com — free
HF_TOKEN=your_huggingface_token_here             # huggingface.co — free

# --- Image Generation ---
# ComfyUI runs locally — no key needed
COMFYUI_HOST=http://127.0.0.1:8188
# Pollinations — no key needed (free, unlimited)
POLLINATIONS_BASE=https://image.pollinations.ai/prompt

# --- Instagram Graph API (Free — needs Facebook Developer account) ---
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# --- YouTube Data API v3 (Free — 10,000 units/day) ---
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json   # OAuth2 file from Google Console

# --- Google Drive (Free — 15GB storage) ---
GDRIVE_FOLDER_ID=your_google_drive_folder_id
GDRIVE_CREDENTIALS_FILE=gdrive_credentials.json

# --- Reddit API (Free — content research) ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AanyaBot/1.0

# --- System Config ---
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
OUTPUT_DIR=./output
DATA_DIR=./data
CHARACTER_CONFIG=./character/character_config.json

# --- Rate Limits (do not change unless you upgrade plans) ---
GROQ_RPM=30
GROQ_RPD=14400
GEMINI_RPM=15
GEMINI_RPD=1500
YOUTUBE_UNITS_PER_DAY=10000
INSTAGRAM_POSTS_PER_DAY=25
